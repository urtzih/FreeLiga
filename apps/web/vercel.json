{
    "headers": [
        {
            "source": "/sw.js",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                },
                {
                    "key": "Service-Worker-Allowed",
                    "value": "/"
                }
            ]
        },
        {
            "source": "/manifest.webmanifest",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/manifest+json"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/robots.txt",
            "destination": "/robots.txt"
        },
        {
            "source": "/sitemap.xml",
            "destination": "/sitemap.xml"
        },
        {
            "source": "/",
            "destination": "/index.html"
        },
        {
            "source": "/inicio",
            "destination": "/inicio/index.html"
        },
        {
            "source": "/public/groups",
            "destination": "/public/groups/index.html"
        },
        {
            "source": "/public/matches",
            "destination": "/public/matches/index.html"
        },
        {
            "source": "/legal",
            "destination": "/legal/index.html"
        },
        {
            "source": "/privacy",
            "destination": "/privacy/index.html"
        },
        {
            "source": "/terms",
            "destination": "/terms/index.html"
        },
        {
            "source": "/login",
            "destination": "/login/index.html"
        },
        {
            "source": "/dashboard",
            "destination": "/dashboard/index.html"
        },
        {
            "source": "/admin",
            "destination": "/admin/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
