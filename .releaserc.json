{
  "branches": [
    "master"
  ],
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "parserOpts": {
          "noteKeywords": [
            "BREAKING CHANGE",
            "BREAKING CHANGES",
            "CAMBIO IMPORTANTE",
            "CAMBIOS IMPORTANTES"
          ]
        }
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            {
              "type": "feat",
              "section": "Nuevas funcionalidades"
            },
            {
              "type": "fix",
              "section": "Correcciones"
            },
            {
              "type": "perf",
              "section": "Rendimiento"
            },
            {
              "type": "refactor",
              "section": "Refactorizacion"
            },
            {
              "type": "docs",
              "section": "Documentacion"
            },
            {
              "type": "test",
              "section": "Tests"
            },
            {
              "type": "build",
              "section": "Build"
            },
            {
              "type": "ci",
              "section": "CI"
            },
            {
              "type": "chore",
              "section": "Mantenimiento"
            },
            {
              "type": "revert",
              "section": "Reversiones"
            }
          ]
        },
        "parserOpts": {
          "noteKeywords": [
            "BREAKING CHANGE",
            "BREAKING CHANGES",
            "CAMBIO IMPORTANTE",
            "CAMBIOS IMPORTANTES"
          ]
        }
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
