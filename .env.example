# Example environment configuration
# Copy to .env for local development and Docker Compose

# Backend API
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
DATABASE_URL="mysql://freeliga:freeliga123@localhost:3306/freeliga"
JWT_SECRET="change-me"
FRONTEND_URL=http://localhost:4173
ALLOWED_ORIGINS=http://localhost:4173
LOG_LEVEL=debug
PUSH_TRACE=false

# Swagger (optional)
SWAGGER_HOST=localhost:3001
SWAGGER_SCHEMES=http

# Public cache invalidation (optional)
CACHE_INVALIDATE_TOKEN=dev-token
CACHE_METRICS_INTERVAL_MINUTES=10
NOTIFICATION_SCHEDULER_ENABLED=true

# Frontend (Vite)
VITE_API_URL=http://localhost:3001
VITE_API_TIMEOUT=30000

# MySQL (Docker)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=freeliga
MYSQL_USER=freeliga
MYSQL_PASSWORD=freeliga123

# Google Calendar integration (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google-calendar/callback

# SMTP (optional - log alerts)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# Web Push Notifications (required for push features)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
